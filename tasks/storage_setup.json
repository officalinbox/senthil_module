{
  "name": "storage_setup",
  "description": "RHEL LVM Storage Management Task - Create, Extend, and Generic operations with real-time output",
  "input_method": "environment",
  "parameters": {
    "action_type": {
      "description": "Type of operation",
      "type": "Enum[create_storage, extend_lv, generic]",
      "required": true
    },
    "pv_device": {
      "description": "Raw disk for PV (e.g. /dev/sdb)",
      "type": "Optional[String]"
    },
    "vg_name": {
      "description": "Volume Group name. Supports $(hostname) (e.g. $(hostname)_appvg)",
      "type": "Optional[String]"
    },
    "lv_name": {
      "description": "Logical Volume name",
      "type": "Optional[String]"
    },
    "lv_size": {
      "description": "LV size (e.g. 50G, +20G)",
      "type": "Optional[String]"
    },
    "mount_path": {
      "description": "Mount directory (e.g. /app/test)",
      "type": "Optional[String]"
    },
    "fstype": {
      "description": "Filesystem type",
      "type": "Optional[Enum[ext4, xfs]]",
      "default": "ext4"
    },
    "file_owner": {
      "description": "Owner for mount_path (generic mode)",
      "type": "Optional[String]"
    },
    "file_group": {
      "description": "Group for mount_path (generic mode)",
      "type": "Optional[String]"
    },
    "file_mode": {
      "description": "Permissions for mount_path (e.g. 0777)",
      "type": "Optional[String]"
    },
    "package_name": {
      "description": "Package to install",
      "type": "Optional[String]"
    }
  },
  "examples": [
    {
      "description": "Generic mode - Change ownership and permissions",
      "params": {
        "action_type": "generic",
        "mount_path": "/app/test",
        "file_owner": "admin",
        "file_group": "admingrp",
        "file_mode": "0777"
      }
    }
  ]
}
