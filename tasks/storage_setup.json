{
  "name": "storage_setup",
  "description": "RHEL 8 / RHEL 9 LVM Storage Management Task - Create, Extend, or Generic operations with real-time output",
  "input_method": "environment",
  "parameters": {
    "action_type": {
      "description": "Type of storage operation to perform",
      "type": "Enum[create_storage, extend_lv, generic]",
      "required": true
    },
    "pv_device": {
      "description": "Physical Volume device (e.g. /dev/sdb)",
      "type": "Optional[String]"
    },
    "vg_name": {
      "description": "Volume Group name",
      "type": "Optional[String]"
    },
    "lv_name": {
      "description": "Logical Volume name",
      "type": "Optional[String]"
    },
    "lv_size": {
      "description": "Logical Volume size (e.g. 50G, +20G)",
      "type": "Optional[String]"
    },
    "mount_path": {
      "description": "Mount point path (e.g. /data)",
      "type": "Optional[String]"
    },
    "fstype": {
      "description": "Filesystem type (default: ext4)",
      "type": "Optional[Enum[xfs, ext4]]",
      "default": "ext4"
    },
    "package_name": {
      "description": "Package to install via dnf",
      "type": "Optional[String]"
    },
    "file_owner": {
      "description": "Owner for mount path",
      "type": "Optional[String]"
    },
    "file_group": {
      "description": "Group for mount path",
      "type": "Optional[String]"
    },
    "file_mode": {
      "description": "Permissions for mount path (e.g. 0755)",
      "type": "Optional[String]"
    },
    "add_fstab_entry": {
      "description": "Add entry to /etc/fstab",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_daemon_reload": {
      "description": "Run systemctl daemon-reload",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_mount_all": {
      "description": "Run mount -a",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_umount": {
      "description": "Unmount the mount_path",
      "type": "Optional[Boolean]",
      "default": false
    },
    "hosts_entry": {
      "description": "Line to add to /etc/hosts",
      "type": "Optional[String]"
    }
  },
  "examples": [
    {
      "description": "Create new storage with ext4",
      "params": {
        "action_type": "create_storage",
        "pv_device": "/dev/sdb",
        "vg_name": "datavg",
        "lv_name": "datalv",
        "lv_size": "100G",
        "mount_path": "/data"
      }
    },
    {
      "description": "Extend existing Logical Volume",
      "params": {
        "action_type": "extend_lv",
        "vg_name": "datavg",
        "lv_name": "datalv",
        "lv_size": "+50G",
        "mount_path": "/data"
      }
    }
  ]
}
