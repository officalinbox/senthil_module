{
  "name": "storage_setup",
  "description": "RHEL 8 / RHEL 9 LVM Storage Management - Create, Extend storage with real-time console output. Supports dynamic hostname in names.",
  "input_method": "environment",
  "parameters": {
    "action_type": {
      "description": "Operation type to perform",
      "type": "Enum[create_storage, extend_lv, generic]",
      "required": true
    },
    "pv_device": {
      "description": "Physical device for PV (e.g. /dev/sdb, /dev/nvme1n1)",
      "type": "Optional[String]"
    },
    "vg_name": {
      "description": "Volume Group name. Supports $(hostname) or ${HOSTNAME} (e.g. $(hostname)_appvg)",
      "type": "Optional[String]"
    },
    "lv_name": {
      "description": "Logical Volume name. Supports $(hostname) (e.g. $(hostname)_data)",
      "type": "Optional[String]"
    },
    "lv_size": {
      "description": "Size of LV (e.g. 50G, 100G, +20G for extend)",
      "type": "Optional[String]"
    },
    "mount_path": {
      "description": "Mount point directory (e.g. /app, /data)",
      "type": "Optional[String]"
    },
    "fstype": {
      "description": "Filesystem type",
      "type": "Optional[Enum[ext4, xfs]]",
      "default": "ext4"
    },
    "package_name": {
      "description": "Additional package to install (e.g. lvm2, xfsprogs)",
      "type": "Optional[String]"
    },
    "file_owner": {
      "description": "Owner of the mount directory",
      "type": "Optional[String]",
      "default": "root"
    },
    "file_group": {
      "description": "Group of the mount directory",
      "type": "Optional[String]",
      "default": "root"
    },
    "file_mode": {
      "description": "Permissions for mount directory (e.g. 0755, 0770)",
      "type": "Optional[String]"
    },
    "add_fstab_entry": {
      "description": "Add entry to /etc/fstab",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_daemon_reload": {
      "description": "Execute systemctl daemon-reload",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_mount_all": {
      "description": "Execute mount -a",
      "type": "Optional[Boolean]",
      "default": false
    },
    "do_umount": {
      "description": "Unmount the target mount_path before operation",
      "type": "Optional[Boolean]",
      "default": false
    },
    "hosts_entry": {
      "description": "Optional line to append to /etc/hosts",
      "type": "Optional[String]"
    }
  },
  "examples": [
    {
      "description": "Create storage with dynamic hostname",
      "params": {
        "action_type": "create_storage",
        "pv_device": "/dev/sdb",
        "vg_name": "$(hostname)_appvg",
        "lv_name": "data",
        "lv_size": "100G",
        "mount_path": "/app",
        "fstype": "ext4"
      }
    },
    {
      "description": "Extend existing volume",
      "params": {
        "action_type": "extend_lv",
        "vg_name": "$(hostname)_appvg",
        "lv_name": "data",
        "lv_size": "+50G",
        "mount_path": "/app"
      }
    }
  ]
}
