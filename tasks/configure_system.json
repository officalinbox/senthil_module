{
  "name": "your_module::configure_system",
  "description": "RHEL 8/9 - Package, LVM, Mount, chown/chmod, IP, hosts with real output",
  "input_method": "environment",
  "parameters": {
    "package": {
      "description": "Package to install (e.g. httpd, nfs-utils)",
      "type": "Optional[String]"
    },
    "disk": {
      "description": "Disk for LVM (e.g. /dev/sdb)",
      "type": "Optional[String]"
    },
    "vg_name": {
      "description": "Volume Group name",
      "type": "Optional[String]"
    },
    "lv_name": {
      "description": "Logical Volume name",
      "type": "Optional[String]"
    },
    "mount_point": {
      "description": "Mount point (e.g. /data)",
      "type": "Optional[String]"
    },
    "fs_type": {
      "description": "Filesystem type (xfs or ext4)",
      "type": "Optional[String]"
    },
    "chown": {
      "description": "Owner:Group (e.g. root:root, appuser:apps)",
      "type": "Optional[String]"
    },
    "permissions": {
      "description": "Permissions (e.g. 755, 775)",
      "type": "Optional[String]"
    },
    "ip_address": {
      "description": "Static IP (e.g. 192.168.10.50/24)",
      "type": "Optional[String]"
    },
    "interface": {
      "description": "Network interface (e.g. ens18)",
      "type": "Optional[String]"
    },
    "hosts_entry": {
      "description": "Line to add in /etc/hosts",
      "type": "Optional[String]"
    }
  }
}
